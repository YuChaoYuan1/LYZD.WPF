<Window x:Class="LYZD.WPF.View.Windows.Window_MessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LYZD.WPF.View.Windows"
        mc:Ignorable="d"
            Title="AddSchema" Height="450" Width="800"
       WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True" 
        Background="Transparent">
    <Window.Effect>
        <DropShadowEffect Color="Gray"   ShadowDepth="0" BlurRadius="5" Opacity="1" Direction="0.5"/>
    </Window.Effect>
    <Border BorderThickness="1"    Margin="2" UseLayoutRounding="True"  >
        <Grid Background="White"  >
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid   Background="#00027B"    MouseMove="Window_MouseMove">
                <StackPanel Orientation="Horizontal"  VerticalAlignment="Center"  HorizontalAlignment="Left" >
                    <Image Source="/Images/Warn.png" Width="20" Height="20" Margin="10 0 0 0"/>
                    <TextBlock Text="提示信息" Margin="5 0 "   VerticalAlignment="Center" Foreground="White" FontSize="14"/>
                </StackPanel>

                <StackPanel  HorizontalAlignment="Right"  
                    Orientation="Horizontal"
                    Grid.Row="0">
                    <StackPanel.Resources>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="Button"   x:Key="StyleBorderClose">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Red"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Resources>
                    <Button Background="Transparent" Style="{Binding StyleBorderClose}" BorderThickness="0" Click="Button_Click">
                        <Image Width="24"  Name="imageClose"  VerticalAlignment="Top" Source="/Images/Close.png"/>
                    </Button>
                </StackPanel>



            </Grid>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height=" auto"/>
                </Grid.RowDefinitions>
                <Border  BorderThickness="2" Margin="15,10" BorderBrush="#d3d3d3">
                    <ScrollViewer   HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" >
                        <TextBlock  VerticalAlignment="Center"  Name="textBlock" TextWrapping="Wrap"  
                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"  HorizontalAlignment="Center"  FontSize="20"/>
                    </ScrollViewer>
                </Border>
   
                <StackPanel Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Button  Margin="5"  Width="55" Height="25"    Content="复制内容" Background="#2ea400"   Style="{Binding}" BorderThickness="0" Foreground="White" Click="Copy_Button_Click"  />
                    <TextBlock Text="" Name="copytext" VerticalAlignment="Center" Margin="5 0"/>
                </StackPanel>

                <Button  Margin="5" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="100" Height="35"
                    Content="确  定" Background="#2ea400"   Style="{Binding}" FontSize="20" BorderThickness="0" Foreground="White" Click="Button_Click"  />
            </Grid>
        </Grid>
    </Border>
</Window>
