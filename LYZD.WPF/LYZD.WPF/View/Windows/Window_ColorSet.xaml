<Window x:Class="LYZD.WPF.View.Windows.Window_ColorSet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LYZD.WPF.View.Windows"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Title="Window_ColorSet" 
        Height="680" Width="460"
        MouseMove="Window_MouseMove"
        ResizeMode="NoResize" 
        Background="Transparent"
       Foreground="#c8c6c7">
    <Window.Resources>
        <local:SetColorData x:Key="SetColorData"/>
    </Window.Resources>
    <Border BorderThickness="1"  Background="#33343b" Margin="5">
        <Border.Effect>
            <DropShadowEffect Color="Black"  ShadowDepth="0" BlurRadius="5" Opacity="0.5" Direction="0"></DropShadowEffect>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition />
                <RowDefinition  Height="60"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.Resources>
                    <Style TargetType="Border"   x:Key="StyleBorderClose">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Red"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Resources>
                <Border Style="{StaticResource StyleBorderClose}"  Border.MouseLeftButtonDown="StackPanel_MouseLeftButtonDown"  Margin="0,0" Width="32" Height="32"  VerticalAlignment="Top" HorizontalAlignment="Right" >
                    <Image Width="32"  Name="imageClose"  VerticalAlignment="Top" HorizontalAlignment="Right"    Source="/Images/Close.png"  />
                </Border>
                <TextBlock Text="颜色设置" FontSize="18" Margin="5" HorizontalAlignment="Left"/>
            </Grid>

            <Grid Grid.Row="1" Margin="40 20 40 10"  DataContext="{StaticResource SetColorData}">

                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Border Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="窗口背景色" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 窗口背景色}"  Tag="窗口背景色" Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="窗口背景深色" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 窗口背景深色}" Tag="窗口背景深色"  Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="2" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="分隔条颜色" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 分隔条颜色}" Tag="分隔条颜色" Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="3" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="边框颜色浅" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 边框颜色浅}"  Tag="边框颜色浅" Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="4" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="边框颜色" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 边框颜色}"  Tag="边框颜色" Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="5" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="字体颜色浅" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 字体颜色浅}"  Tag="字体颜色浅"  Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="6" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="字体颜色标准" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 字体颜色标准}"  Tag="字体颜色标准"  Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="7" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="屏幕颜色" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 屏幕颜色}"  Tag="屏幕颜色" Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="8" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="表行颜色" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 表行颜色}"  Tag="表行颜色" Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="9" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="表行颜色1" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 表行颜色1}" Tag="表行颜色1" Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="10" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="工作状态颜色" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 工作状态颜色}"  Tag="工作状态颜色" Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="11" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="控件有效颜色" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 控件有效}"  Tag="控件有效" Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="12" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="窗口背景半透明" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 窗口背景深色半透明}"  Tag="窗口背景深色半透明"  Width="60" Height="15" MouseDown="Border_MouseDown"/>
                    </StackPanel>
                </Border>
                <Border Grid.Row="13" Background="Transparent" BorderThickness="0 0 0 1" BorderBrush="#c8c6c7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="00 0 0 0">
                        <TextBlock Text="线性渐变颜色" Margin="0 0 10 0" TextAlignment="Center" Width="100"/>
                        <Border Background="{Binding 线性渐变颜色}"  Tag="线性渐变颜色"  Width="60" Height="15" MouseDown="Border_MouseDown"/>
                        <!--<Border Background="{Binding 线性渐变色}" Width="15" Height="15" Margin="10 0 10 0" ToolTip="渐变深色"/>
                        <Border Background="{Binding 线性渐变色}" Width="15" Height="15"  ToolTip="渐变浅色"/>-->
                    </StackPanel>
                </Border>
            </Grid>
            
            
            <StackPanel Orientation="Horizontal" Grid.Row="2" VerticalAlignment="Center" Margin="50 0 0 0" Name="Panel_ZhuTi" >
                <TextBlock Text="主题" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 20">
                <Button Content="恢复默认设置"  Height="40" Width="160"  Background="#292a2e" Style="{Binding}"
                        Foreground="#c8c6c7" Margin="0 0 30 0" BorderThickness="0"  Click="Btn_Default"/>
                <Button Content="确        定"  Height="40" Width="160"  Background="#292a2e" Style="{Binding}"
                        Foreground="#c8c6c7" BorderThickness="0"  Click="Btn_Save" />
            </StackPanel>

        </Grid>
    </Border>
</Window>
