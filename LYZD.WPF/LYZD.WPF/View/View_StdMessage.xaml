<basemodel:DockControlDisposable  xmlns:basemodel="clr-namespace:LYZD.WPF.Model"
                                  x:Class="LYZD.WPF.View.View_StdMessage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LYZD.WPF.View"
      mc:Ignorable="d" 
      Foreground="{DynamicResource 字体颜色标准}"
      HorizontalAlignment="Left"
      d:DesignHeight="100"
      d:DesignWidth="250" >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="55*"/>
            <RowDefinition Height="191*"/>
        </Grid.RowDefinitions>
        <Viewbox Stretch="Uniform" Margin="0,0,-0.2,-0.4" Grid.RowSpan="2">
            <Grid  Width="350" VerticalAlignment="Top" >
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Grid.Column="1" >
                    <Grid     Height="120" Width="350">
                        <Grid.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#2E2EFE"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="12"/>
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="4*"/>
                            <RowDefinition Height="1.2*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="1" >
                            <Grid.Resources>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Black" />
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="3.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="3.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="3.2*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="P" Grid.Column="0"  FontSize="18" />
                            <TextBlock Text="Q" Grid.Column="2"  FontSize="18" />
                            <TextBlock Text="S" Grid.Column="4"  FontSize="18" />
                            <TextBlock Grid.Column="1" HorizontalAlignment="Left"  FontSize="16"   Text="{Binding  P, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Column="3"  HorizontalAlignment="Left"   FontSize="16"   Text="{Binding  Q, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Column="5"  HorizontalAlignment="Left"   FontSize="16"   Text="{Binding  S, StringFormat=\{0:F4\}}"/>
                        </Grid>
                        <Grid Grid.Row="0">
                            <Grid.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#A9D0F5"/>
                                    <Setter Property="BorderThickness" Value="0.5"/>
                                </Style>
                            </Grid.Resources>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="1"  Background="#58ACFA"/>
                            <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="1" Grid.ColumnSpan="1"  Background="#58ACFA"/>
                            <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="1" Grid.ColumnSpan="1"  Background="#58ACFA"/>
                            <Border Grid.Row="0" Grid.Column="3" Grid.RowSpan="1" Grid.ColumnSpan="1"  Background="#58ACFA"/>
                            <Border Grid.Row="0" Grid.Column="4" Grid.RowSpan="1" Grid.ColumnSpan="1"  Background="#58ACFA"/>
                            <Border Grid.Row="0" Grid.Column="5" Grid.RowSpan="1" Grid.ColumnSpan="1"  Background="#58ACFA"/>
                            <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                            <Border Grid.Row="2" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                            <Border Grid.Row="3" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="1"  />


                            <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="3" Grid.ColumnSpan="1"/>
                            <Border Grid.Row="1" Grid.Column="2" Grid.RowSpan="3" Grid.ColumnSpan="1"/>
                            <Border Grid.Row="1" Grid.Column="3" Grid.RowSpan="3" Grid.ColumnSpan="1"/>
                            <Border Grid.Row="1" Grid.Column="4" Grid.RowSpan="3" Grid.ColumnSpan="1"/>
                            <Border Grid.Row="1" Grid.Column="5" Grid.RowSpan="3" Grid.ColumnSpan="1"/>
                            <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="1" Grid.ColumnSpan="5" />
                            <Border Grid.Row="2" Grid.Column="1" Grid.RowSpan="1" Grid.ColumnSpan="5"/>
                            <Border Grid.Row="3" Grid.Column="1" Grid.RowSpan="1" Grid.ColumnSpan="5"/>
                            <TextBlock Text="A" Grid.Row="1"  FontSize="15"  Foreground="Yellow" />
                            <TextBlock Text="B" Grid.Row="2"  FontSize="15"  Foreground="Green"  />
                            <TextBlock Text="C" Grid.Row="3"  FontSize="15" Foreground="red" />
                            <TextBlock Text="U" Grid.Row="0"   Grid.Column="1"   FontSize="15" Margin=" -11 2 0 0" />
                            <TextBlock Text="I" Grid.Row="0"   Grid.Column="2"   FontSize="15" Margin=" -11 2 0 0"  />
                            <TextBlock Text="P" Grid.Row="0"   Grid.Column="3"   FontSize="15" Margin=" -11 2 0 0"  />
                            <TextBlock Text="Q" Grid.Row="0"   Grid.Column="4"   FontSize="15" Margin=" -14 2 0 0"  />
                            <TextBlock Text="Φ" Grid.Row="0"  Grid.Column="5"   FontSize="15" Margin=" -11 2 0 0"  />
                            <TextBlock Text="(V)" Grid.Row="0"    Grid.Column="1"   FontSize="9" Margin="11 2 0 0" />
                            <TextBlock Text="(A)" Grid.Row="0"    Grid.Column="2"   FontSize="9" Margin=" 11 2 0 0" />
                            <TextBlock Text="(W)" Grid.Row="0"    Grid.Column="3"   FontSize="9" Margin=" 11 2 0 0" />
                            <TextBlock Text="(Va)" Grid.Row="0"    Grid.Column="4"   FontSize="9" Margin=" 14 2 0 0" />
                            <TextBlock Text="(°)" Grid.Row="0"    Grid.Column="5"   FontSize="9" Margin=" 11 2 0 0" />


                            <TextBlock Grid.Row="1"   Grid.Column="1"  Foreground="Yellow" FontSize="11"  Text="{Binding Ua, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Row="1"   Grid.Column="2"  Foreground="Yellow" FontSize="11"  Text="{Binding Ia, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Row="1"   Grid.Column="3"  Foreground="Yellow" FontSize="11"  Text="{Binding Pa, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Row="1"   Grid.Column="4"  Foreground="Yellow" FontSize="11"  Text="{Binding Qa, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Row="1"   Grid.Column="5"  Foreground="Yellow" FontSize="11"  Text="{Binding PhaseA, StringFormat=\{0:F4\}}"/>

                            <TextBlock Grid.Row="2"   Grid.Column="1" Foreground="Green"  FontSize="11" Text="{Binding  Ub, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Row="2"   Grid.Column="2" Foreground="Green"  FontSize="11" Text="{Binding  Ib, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Row="2"   Grid.Column="3" Foreground="Green"  FontSize="11" Text="{Binding  Pb, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Row="2"   Grid.Column="4" Foreground="Green"  FontSize="11" Text="{Binding  Qb, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Row="2"   Grid.Column="5" Foreground="Green"  FontSize="11" Text="{Binding PhaseB, StringFormat=\{0:F4\}}"/>

                            <TextBlock Grid.Row="3"   Grid.Column="1"  Foreground="red"  FontSize="11" Text="{Binding Uc, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Row="3"   Grid.Column="2"  Foreground="red"  FontSize="11" Text="{Binding Ic, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Row="3"   Grid.Column="3"  Foreground="red"  FontSize="11" Text="{Binding Pc, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Row="3"   Grid.Column="4"  Foreground="red"  FontSize="11" Text="{Binding Qc, StringFormat=\{0:F4\}}"/>
                            <TextBlock Grid.Row="3"   Grid.Column="5"  Foreground="red"  FontSize="11" Text="{Binding PhaseC, StringFormat=\{0:F4\}}"/>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Grid>
        </Viewbox>
    </Grid>

</basemodel:DockControlDisposable>
