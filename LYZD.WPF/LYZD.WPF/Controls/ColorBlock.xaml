<UserControl x:Class="LYZD.WPF.Controls.ColorBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LYZD.WPF.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="32" d:DesignWidth="32">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Background="{Binding ThemeBrush}" Margin="1 1 0.5 0.5" />
        <Border Background="{Binding ThemeBrush}" Grid.Row="0" Grid.Column="1"  Margin="1 1 0.5 0.5" />
        <Border Background="{Binding ThemeBrush}" Grid.Row="1" Grid.Column="0"  Margin="1 1 0.5 0.5" />
        <Border Background="{Binding ThemeBrush}" Grid.Row="1" Grid.Column="1"  Margin="1 1 0.5 0.5" />
    </Grid>
</UserControl>
