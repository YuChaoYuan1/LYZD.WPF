<UserControl x:Class="LYZD.WPF.Controls.PhaseDiagram"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LYZD.WPF.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="101" d:DesignWidth="101">
    <Grid Width="101" Height="101" >
        <Border  BorderBrush="Black" BorderThickness="1" CornerRadius="50"/>

        <!--Ua-->
        <StackPanel Orientation="Vertical" Width="10.5" Margin="5">
            <TextBlock Text="Ua" Width="10" Foreground="Red" FontSize="5" TextAlignment="Center"/>
            <Border Background="red" Width="1" Height="40" VerticalAlignment="Center"  HorizontalAlignment="Center" />
            <StackPanel.RenderTransform>
                <RotateTransform  CenterX="5" CenterY="45.5" Angle="0" />
            </StackPanel.RenderTransform>
        </StackPanel>
        <!--Ia-->
        <StackPanel Orientation="Vertical" Width="10.5" Margin="5">
            <TextBlock Text="Ia" Width="10" Foreground="red" FontSize="5" TextAlignment="Center" Margin="0 5 0 0"/>
            <Border Background="red" Width="1" Height="35" VerticalAlignment="Center"  HorizontalAlignment="Center"/>
            <StackPanel.RenderTransform>
                <RotateTransform  CenterX="5" CenterY="45.5" Angle="30" />
            </StackPanel.RenderTransform>
        </StackPanel>


        <!--Ub-->
        <StackPanel Orientation="Vertical" Width="10.5" Margin="5">
            <TextBlock Text="Ub" Width="10" Foreground="Green" FontSize="5" TextAlignment="Center"/>
            <Border Background="Green" Width="1" Height="40" VerticalAlignment="Center"  HorizontalAlignment="Center"/>
            <StackPanel.RenderTransform>
                <RotateTransform  CenterX="5" CenterY="45.5" Angle="240" />
            </StackPanel.RenderTransform>
        </StackPanel>
         <!--Ib-->
        <StackPanel Orientation="Vertical" Width="10.5" Margin="5">
            <TextBlock Text="Ib" Width="10" Foreground="Green" FontSize="5" TextAlignment="Center" Margin="0 5 0 0"/>
            <Border Background="Green" Width="1" Height="35" VerticalAlignment="Center"  HorizontalAlignment="Center"/>
            <StackPanel.RenderTransform>
                <RotateTransform  CenterX="5" CenterY="45.5" Angle="60" />
            </StackPanel.RenderTransform>
        </StackPanel>

        <!--Uc-->
        <StackPanel Orientation="Vertical" Width="10.5" Margin="5">
            <TextBlock Text="Uc" Width="10" Foreground="#AEB404" FontSize="5" TextAlignment="Center"/>
            <Border Background="#AEB404" Width="1" Height="40" VerticalAlignment="Center"  HorizontalAlignment="Center"/>
            <StackPanel.RenderTransform>
                <RotateTransform  CenterX="5" CenterY="45.5" Angle="140" />
            </StackPanel.RenderTransform>
        </StackPanel>
           <!--Ic-->
        <StackPanel Orientation="Vertical" Width="10.5" Margin="5">
            <TextBlock Text="Ic" Width="10" Foreground="#AEB404" FontSize="5" TextAlignment="Center" Margin="0 5 0 0"/>
            <Border Background="#AEB404" Width="1" Height="35" VerticalAlignment="Center"  HorizontalAlignment="Center"/>
            <StackPanel.RenderTransform>
                <RotateTransform  CenterX="5" CenterY="45.5" Angle="90" />
            </StackPanel.RenderTransform>
        </StackPanel>

        <Border  Background="Black"  Width="5" Height="5"  CornerRadius="50" Margin="0"/>
        
        <!--<Path Data="M 0 3 L 0 4 L 5 0  L 10 3 L 10 4  L 5 0 Z" >
                <Path.Fill>
                    <SolidColorBrush Color="red" />
                </Path.Fill>
            </Path>-->

        <!--<StackPanel.RenderTransform>
                <RotateTransform  CenterX="5" CenterY="45" Angle="180" />
            </StackPanel.RenderTransform>-->
    </Grid>
</UserControl>
