<UserControl x:Class="LYZD.WPF.Controls.UserMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Converter="clr-namespace:LYZD.WPF.Converter"
             mc:Ignorable="d" 
              Background="{DynamicResource 窗口背景深色}"
             Height="90"
             Foreground="{DynamicResource 字体颜色标准}"
             MouseMove="UserControl_MouseMove"
             d:DesignHeight="60" d:DesignWidth="1280">
    <UserControl.Resources>
        <Converter:NotBoolConverter x:Key="NotBoolConverter"/>
    </UserControl.Resources>
    <Grid>

        <!--<Border VerticalAlignment="Top" Height="40" Background="#2E2EFE">
            <Grid>
                <StackPanel VerticalAlignment="Top"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal"
                        Margin="8,0,0,0"
                        Name="stackPannelLogo">
                    <Image Margin="5,5,5,3"
                   Height="30"
                   Width="30"
                   VerticalAlignment="Bottom"
                     HorizontalAlignment="Right"
                     Source="/Images/Logo2.png" />
                    <TextBlock Text="深圳隆元科技有限公司" VerticalAlignment="Center"  FontSize="20" Name="TestName"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Margin="8,8,0,0"
                        Name="stackPannelSysName">
                    <TextBlock Name="textBlockSoftWareName"  Margin="0,0,5,0"
                   VerticalAlignment="Bottom"  FontSize="16" FontFamily="Calibri"/>
                    <TextBlock  Name="textVersion" FontSize="16"
                        VerticalAlignment="Bottom" HorizontalAlignment="Right" Text="隆元科技电测系统" Visibility="Collapsed"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" 
                    Margin="5"
                    Border.MouseLeftButtonDown="StackPanel_MouseLeftButtonDown"
                    Orientation="Horizontal"
                    VerticalAlignment="Top">
                    <StackPanel.Resources>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="Border"   x:Key="StyleBorderClose">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Red"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Resources>
                    <Border  Margin="0,0,20,0">
                        <TextBlock Text="{DynamicResource 数据管理}"
                           Name="TextDataManager"
                           Margin="5,0"
                           FontSize="16"
                           VerticalAlignment="Center" />
                    </Border>
                    <Border Margin="3,5">
                        <Image Width="24"  Name="ThemeChoice"
                  VerticalAlignment="Top"
                Source="/Images/Theme.png"  ToolTip="主题颜色修改" Visibility="Collapsed"/>
                    </Border>
                        <Border Margin="3,5">
                            <Image Width="24"  Name="imageMin"
                      VerticalAlignment="Top"
                    Source="/Images/Min.png" />
                        </Border>
                    <Border Margin="3,5" Name="borderMax">
                        <Image Width="24" Name="imageMax"
                   VerticalAlignment="Top"  Source="/Images/Reduction.png" />
                    </Border>
                    <Border Style="{StaticResource StyleBorderClose}"   Margin="3,5" >
                        <Image Width="24"  Name="imageClose"  VerticalAlignment="Top"
                Source="/Images/Close.png"  />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
        <Grid Width="300" Height="50"  HorizontalAlignment="Right" Margin="0 40 60 0"  Name="VerifyGrid" Visibility="Collapsed" >
            <Border CornerRadius="15"
			        BorderThickness="1"
                    BorderBrush="{DynamicResource 边框颜色}"
                    Background="{DynamicResource 窗口背景深色半透明}" 
                    Name="TestMain" >
                --><!--Visibility="{Binding IsTestMainVisible, Converter={StaticResource BoolToVisibilityConverter},Mode=TwoWay}"--><!--
                <Border.Effect>
                    <DropShadowEffect Color="Gray"  ShadowDepth="0" BlurRadius="3" Opacity="0.5" Direction="0"></DropShadowEffect>
                </Border.Effect>

                <StackPanel Margin="0" Orientation="Horizontal"  IsEnabled="{Binding IsEnable}" x:Name="stackPanelController" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Resources>
                        <Style TargetType="{x:Type dc:ButtonDropDown}">
                            <Setter Property="Margin" Value="5,0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                        <Style TargetType="Image">
                            <Setter Property="Width" Value="45"/>
                        </Style>
                    </StackPanel.Resources>
                    <dc:ButtonDropDown Command="{Binding LocalCommand}"
						       CommandParameter="RunningVerify"
						       IsEnabled="{Binding IsChecking, Converter={StaticResource NotBoolConverter}}"
						       ImagePosition="Top"
                               ToolTip="连续检定,执行完当前检定项后检查下一个项目."
                               Cursor="Hand">
                        <dc:ButtonDropDown.Image>
                            <Image Source="/Images/Continuity.png"/>
                        </dc:ButtonDropDown.Image>
                    </dc:ButtonDropDown>
                    <dc:ButtonDropDown Command="{Binding LocalCommand}"
						       CommandParameter="StepVerify"
						       IsEnabled="{Binding IsChecking, Converter={StaticResource NotBoolConverter}}"
						       ToolTip="单步检定,执行完当前检定项后停止检定."
						       ImagePosition="Top">
                        <dc:ButtonDropDown.Image>
                            <Image Source="/Images/Start.png"/>
                        </dc:ButtonDropDown.Image>
                    </dc:ButtonDropDown>
                    <dc:ButtonDropDown Command="{Binding LocalCommand}"
						       CommandParameter="LoopVerify"
						       IsEnabled="{Binding IsChecking, Converter={StaticResource NotBoolConverter}}"
						       ToolTip="一直循环执行当前的检定项"
						       ImagePosition="Top">
                        <dc:ButtonDropDown.Image>
                            <Image   Source="/Images/Run.png"/>
                        </dc:ButtonDropDown.Image>
                    </dc:ButtonDropDown>
                    <dc:ButtonDropDown Command="{Binding LocalCommand}"
						       CommandParameter="StopVerify"
						       ToolTip="停止当前检定"
						       ImagePosition="Top"
						       IsEnabled="{Binding IsChecking}">
                        <dc:ButtonDropDown.Image>
                            <Image   Source="/Images/Stop.png"/>
                        </dc:ButtonDropDown.Image>
                    </dc:ButtonDropDown>
                    <dc:ButtonDropDown Command="{Binding LocalCommand}"
						       CommandParameter="MeterDebug"
						       IsEnabled="{Binding IsChecking}"
						       ImagePosition="Top"
                               ToolTip="锁定当前项目,进行调表"
                               Cursor="Hand">
                        <dc:ButtonDropDown.Image>
                            <Image Width="45" >
                                <Image.Resources>
                                    <Style TargetType="Image">
                                        <Setter Property="Source" Value="/Images/Unlock.png"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMeterDebug}" Value="false">
                                                <Setter Property="Source" Value="/Images/Unlock.png"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMeterDebug}" Value="true">
                                                <Setter Property="Source" Value="/Images/Locking.png"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Resources>
                            </Image>
                        </dc:ButtonDropDown.Image>
                    </dc:ButtonDropDown>
                </StackPanel>



            </Border>
        </Grid>

        <StackPanel VerticalAlignment="Bottom"
                        HorizontalAlignment="Left"
                        Orientation="Horizontal"
                        Margin="10,0,0,0"
                        Name="stackPannelMenu">
        </StackPanel>

        <StackPanel Orientation="Horizontal" 
                        Margin="8,8,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top">
        </StackPanel>-->

       
    </Grid>
</UserControl>
