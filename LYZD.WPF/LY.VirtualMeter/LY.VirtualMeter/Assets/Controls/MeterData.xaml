<UserControl x:Class="LY.VirtualMeter.Assets.Controls.MeterData"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LY.VirtualMeter.Assets.Controls"
             mc:Ignorable="d"
             Width="150" Height="120">
    <Border  Background="Transparent" BorderBrush="#0080FF" BorderThickness="1.3"   Margin="2 0 2 8">
        <Grid >
            <Grid.RowDefinitions>
                <RowDefinition Height="1.2*"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" >
                <TextBlock Text="{Binding Index}" FontSize="18" Foreground="#36a6cd" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Button Content="详情" VerticalAlignment="Center" HorizontalAlignment="Right"  Width="23" Height="14" FontSize="10"
                    Style="{StaticResource ButtonStyle }"  Margin=" 0 0 2 0" Background="#FF6800" Click="Button_Click" Name="test"/>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.Resources>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="#A9D0F5"/>
                        <Setter Property="BorderThickness" Value="0.5"/>
                    </Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Foreground"  Value="white"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin"  Value="3,0,3,0"/>
                    </Style>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="1"  Background="#5F58ACFA"/>
                <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="1" Grid.ColumnSpan="1"  Background="#5F58ACFA"/>
                <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="2" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="2" Grid.Column="1" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <TextBlock Text="地址" Grid.Row="0"   Grid.Column="0"  HorizontalAlignment="Right"/>
                <TextBlock Text="电量" Grid.Row="1"   Grid.Column="0"  HorizontalAlignment="Right"/>
                <TextBlock Text="时间" Grid.Row="2"   Grid.Column="0"  HorizontalAlignment="Right"/>

                <TextBlock Text="{Binding BAddress}" Grid.Row="0"   Grid.Column="1"  HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding 当前显示电量}" Grid.Row="1"   Grid.Column="1"  HorizontalAlignment="Left"/>
                <TextBlock Text="{Binding 当前显示时间}" Grid.Row="2"   Grid.Column="1"  HorizontalAlignment="Left"/>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.Resources>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="#A9D0F5"/>
                        <Setter Property="BorderThickness" Value="0.5"/>
                    </Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="Foreground"  Value="white"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Margin"  Value="3,0,3,0"/>
                    </Style>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.7*"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="0.7*"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="0.7*"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="0" Grid.Column="3" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="0" Grid.Column="4" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="0" Grid.Column="5" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="1" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="1" Grid.Column="2" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="1" Grid.Column="3" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="1" Grid.Column="4" Grid.RowSpan="1" Grid.ColumnSpan="1"  />
                <Border Grid.Row="1" Grid.Column="5" Grid.RowSpan="1" Grid.ColumnSpan="1"  />

                <TextBlock Text="Ua" Grid.Row="0"   Grid.Column="0"  HorizontalAlignment="Center"/>
                <TextBlock Text="Ub" Grid.Row="0"   Grid.Column="2"  HorizontalAlignment="Center"/>
                <TextBlock Text="Uc" Grid.Row="0"   Grid.Column="4"  HorizontalAlignment="Center"/>
                <TextBlock Text="Ia" Grid.Row="1"   Grid.Column="0"  HorizontalAlignment="Center"/>
                <TextBlock Text="Ib" Grid.Row="1"   Grid.Column="2"  HorizontalAlignment="Center"/>
                <TextBlock Text="Ic" Grid.Row="1"   Grid.Column="4"  HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding Ua}" Grid.Row="0"   Grid.Column="1"  HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Ub}" Grid.Row="0"   Grid.Column="3"  HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Uc}" Grid.Row="0"   Grid.Column="5"  HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding Ia}" Grid.Row="1"   Grid.Column="1"  HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Ib}" Grid.Row="1"   Grid.Column="3"  HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Ic}" Grid.Row="1"   Grid.Column="5"  HorizontalAlignment="Center"/>
            </Grid>
        </Grid>
    </Border>

   
</UserControl>
